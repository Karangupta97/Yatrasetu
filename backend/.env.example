PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend URL (used for email verification links) ──────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Aadhaar hashing salt (never change after first user is created) ───────────
AADHAAR_SALT=

# ── AWS SES ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=

# ── Sandbox.co.in (Aadhaar OKYC) ─────────────────────────────────────────────
SANDBOX_API_KEY=
SANDBOX_AUTH_TOKEN=
